# Data Doctor Environment Configuration

# Application Settings
DEBUG=true
APP_NAME="Data Doctor"
APP_VERSION="0.1.0"

# OpenMetadata Configuration
# For local development:
# OPENMETADATA_HOST_PORT=http://localhost:8585/api
# For deployment (replace with your server IP/domain):
# OPENMETADATA_HOST_PORT=http://your-server-ip:8585/api
# OPENMETADATA_HOST_PORT=https://your-domain.com:8585/api
OPENMETADATA_HOST_PORT=http://localhost:8585/api
OPENMETADATA_JWT_TOKEN=your_jwt_token_here

# API Configuration
API_V1_PREFIX=/api/v1
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# Demo Configuration
DEMO_SCENARIO_FQN=sample_mysql_service.ecommerce_sample.dim_customer

# AI Enhancement Layer (Optional)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Governance Tagging (Optional)
ENABLE_GOVERNANCE_TAGGING=false
GOVERNANCE_TAG_CLASSIFICATION=DataQuality
TAG_IMPACTED_ASSETS=true
